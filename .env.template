# =============================================================================
# Swarm Backend Configuration
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Logging ---
LOG_LEVEL=DEBUG

# --- Auth ---
# Set to "development" with empty key to disable auth for local dev.
# Any other value requires SWARM_API_KEY to be set.
ENVIRONMENT=development
SWARM_API_KEY=

# --- Swarm Execution ---
# Max seconds per agent task before timeout (default: 1800 = 30 min)
SWARM_TASK_TIMEOUT=1800
# Max execution rounds per swarm (default: 3)
SWARM_MAX_ROUNDS=3
# LLM model identifier (default: claude-sonnet-4.6)
# Run scripts/list-models.py to see available models
SWARM_MODEL=claude-sonnet-4.6

# --- CORS ---
# Comma-separated list of allowed origins for CORS.
# Adjust for your frontend URL in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Paths ---
# All paths are relative to the working directory (project root).
# Use absolute paths for Docker or non-standard deployments.
SWARM_WORK_DIR=workdir
TEMPLATES_DIR=src/templates
LOGS_DIR=logs
STATIC_DIR=static

# --- Template Packs ---
# Max zip file size for template deploy endpoint (default: 3MB)
SWARM_MAX_TEMPLATE_ZIP_SIZE=3145728

# --- Database Persistence (optional) ---
# Set to enable Postgres persistence for swarm state, event replay, and recovery.
# Leave empty to run without persistence (in-memory only, state lost on restart).
# Requires: docker compose up -d postgres
DATABASE_URL=postgresql+asyncpg://swarm:swarm@localhost:5432/swarm
